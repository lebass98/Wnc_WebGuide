r-slate-300 dark:border-slate-700 w-5 h-5\">\n        <span class=\"text-sm font-semibold flex-1 text-slate-700 dark:text-slate-200\">제품 업데이트 - 2024년 4분기</span>\n        <span class=\"text-xs text-slate-400 dark:text-slate-500\">2027년 2월 12일</span>\n        <img src=\"https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=100&h=100&fit=crop\" class=\"w-7 h-7 rounded-full object-cover\">\n      </div>\n      <!-- Task 7 -->\n      <div class=\"flex items-center gap-4 bg-white dark:bg-[#1A222C] p-4 rounded-xl border border-slate-100 dark:border-slate-800 shadow-sm\">\n        <svg class=\"w-5 h-5 text-slate-300 dark:text-slate-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M4 6h16M4 12h16M4 18h16\" /></svg>\n        <input type=\"checkbox\" class=\"rounded border-slate-300 dark:border-slate-700 w-5 h-5\">\n        <span class=\"text-sm font-semibold flex-1 text-slate-700 dark:text-slate-200\">티켓 인박스 복귀 시 Figbot 댓글 자동화 설정</span>\n        <span class=\"text-xs text-slate-400 dark:text-slate-500\">2027년 3월 8일</span>\n        <img src=\"https://images.unsplash.com/photo-1494790108377-be9c29b29330?w=100&h=100&fit=crop\" class=\"w-7 h-7 rounded-full object-cover\">\n      </div>\n    </div>\n  </div>\n\n  <!-- 3. 완료 -->\n  <div class=\"space-y-4\">\n    <div class=\"flex items-center gap-3\">\n      <h3 class=\"text-lg font-bold text-slate-800 dark:text-white\">완료</h3>\n      <span class=\"px-2 py-0.5 rounded-full bg-slate-100 dark:bg-slate-800 text-xs font-bold text-slate-500 dark:text-slate-400\">4</span>\n    </div>\n    <div class=\"flex flex-col gap-3\">\n      <!-- Task 8 -->\n      <div class=\"flex items-center gap-4 bg-white dark:bg-[#1A222C] p-4 rounded-xl border border-slate-100 dark:border-slate-800 shadow-sm\">\n        <svg class=\"w-5 h-5 text-slate-300 dark:text-slate-600\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><