    "js": "document.addEventListener('DOMContentLoaded', () => {\n  if (typeof lucide !== 'undefined') {\n    lucide.createIcons();\n  }\n});",
    "fullHtml": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest\"></script>\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css\">\n  <title>Error 503 - Service Unavailable</title>\n  <style>\n    body {\n      font-family: 'Pretendard', sans-serif;\n    }\n  </style>\n</head>\n<body class=\"bg-slate-50 dark:bg-slate-900 transition-colors duration-300\">\n  <div class=\"w-full min-h-screen flex items-center justify-center p-4\">\n    <div class=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl transition-all duration-300\">\n      <div class=\"relative\">\n        <svg class=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <rect x=\"40\" y=\"40\" width=\"120\" height=\"120\" rx=\"16\" fill=\"url(#paint0_linear_503)\" />\n          <path d=\"M100 20 L 100 40 M100 160 L 100 180 M20 100 L 40 100 M160 100 L 180 100\" stroke=\"#6366F1\" stroke-width=\"6\" stroke-linecap=\"round\" class=\"animate-pulse\" />\n          <circle cx=\"100\" cy=\"100\" r=\"30\" fill=\"white\" fill-opacity=\"0.2\" />\n          <circle cx=\"100\" cy=\"100\" r=\"15\" fill=\"white\" class=\"animate-ping\" />\n          <defs>\n            <linearGradient id=\"paint0_linear_503\" x1=\"40\" y1=\"40\" x2=\"160\" y2=\"160\" gradientUnits=\"userSpaceOnUse\">\n              <stop stop-color=\"#6366F1\" />\n              <stop offset=\"1\" stop-color=\"#4F46E5\" />\n            </linearGradient>\n          </defs>\n        </svg>\n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-indigo-500 border-indigo-100 dark:border-indigo-900/30 bg-indigo-50 dark:bg-indigo-500/10\">\n          <i data-lucide=\"cpu\" class=\"w-16 h-16 text-indigo-500 animate-spin-slow\" style=\"animation-duration: 6s;\"></i>\n        </div>\n      </div>\n      <div class=\"space-y-3 pt-6\">\n        <span class=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n          503\n        </span>\n        <h2 class=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n          Service Unavailable\n        </h2>\n        <p class=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n          서비스 점검 중입니다.\n        </p>\n        <p class=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n          더 나은 서비스를 제공하기 위해 현재 시스템 점검 및 서버 업그레이드 작업이 진행 중입니다. 곧 안전하고 빠른 서비스로 찾아뵙겠습니다.\n        </p>\n      </div>\n      <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n        <button onclick=\"history.back()\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\">\n          <i data-lucide=\"arrow-left\" class=\"w-4 h-4\"></i>\n          이전으로\n        </button>\n        <button onclick=\"location.href='/'\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\">\n          <i data-lucide=\"home\" class=\"w-4 h-4\"></i>\n          대시보드로 돌아가기\n        </button>\n      </div>\n    </div>\n  </div>\n  <script>\n    lucide.createIcons();\n  </script>\n</body>\n</html>"
