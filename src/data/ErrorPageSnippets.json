{
  "404": {
    "react": "import React from 'react';\nimport { useNavigate } from 'react-router-dom';\nimport { ArrowLeft, Home, ShieldAlert } from 'lucide-react';\n\nconst Error404Page: React.FC = () => {\n  const navigate = useNavigate();\n\n  return (\n    <div className=\"w-full flex items-center justify-center bg-slate-50 dark:bg-slate-900 px-4 py-10 transition-colors duration-300 font-sans\">\n      <div className=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl\">\n        <div className=\"relative\">\n          <svg className=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <circle cx=\"100\" cy=\"100\" r=\"80\" fill=\"url(#paint0_linear_404)\" className=\"animate-pulse\" />\n            <path d=\"M70 120 C 85 105, 115 105, 130 120\" stroke=\"white\" strokeWidth=\"6\" strokeLinecap=\"round\" />\n            <circle cx=\"75\" cy=\"80\" r=\"10\" fill=\"white\" />\n            <circle cx=\"125\" cy=\"80\" r=\"10\" fill=\"white\" />\n            <path d=\"M65 60 L 85 70\" stroke=\"white\" strokeWidth=\"4\" strokeLinecap=\"round\" />\n            <path d=\"M135 60 L 115 70\" stroke=\"white\" strokeWidth=\"4\" strokeLinecap=\"round\" />\n            <defs>\n              <linearGradient id=\"paint0_linear_404\" x1=\"20\" y1=\"20\" x2=\"180\" y2=\"180\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#F43F5E\" />\n                <stop offset=\"1\" stopColor=\"#BE123C\" />\n              </linearGradient>\n            </defs>\n          </svg>\n          <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-rose-500 border-rose-100 dark:border-rose-900/30 bg-rose-50 dark:bg-rose-500/10\">\n            <ShieldAlert className=\"w-16 h-16 text-rose-500 animate-bounce\" />\n          </div>\n        </div>\n        <div className=\"space-y-3 pt-6\">\n          <span className=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n            404\n          </span>\n          <h2 className=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n            Page Not Found\n          </h2>\n          <p className=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n            원하시는 페이지를 찾을 수 없습니다.\n          </p>\n          <p className=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n            입력하신 주소가 잘못되었거나, 페이지가 삭제 혹은 이동되었을 수 있습니다. 주소를 다시 한번 확인해 주세요.\n          </p>\n        </div>\n        <div className=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n          <button\n            onClick={() => navigate(-1)}\n            className=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\"\n          >\n            <ArrowLeft className=\"w-4 h-4\" />\n            이전으로\n          </button>\n          <button\n            onClick={() => navigate('/')}\n            className=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\"\n          >\n            <Home className=\"w-4 h-4\" />\n            대시보드로 돌아가기\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default Error404Page;",
    "html": "<div class=\"w-full flex items-center justify-center bg-slate-50 dark:bg-slate-900 px-4 py-10 transition-colors duration-300 font-sans\">\n  <div class=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl transition-all duration-300\">\n    <!-- Error Badge & Illustration -->\n    <div class=\"relative\">\n      <svg class=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <circle cx=\"100\" cy=\"100\" r=\"80\" fill=\"url(#paint0_linear_404)\" class=\"animate-pulse\" />\n        <path d=\"M70 120 C 85 105, 115 105, 130 120\" stroke=\"white\" stroke-width=\"6\" stroke-linecap=\"round\" />\n        <circle cx=\"75\" cy=\"80\" r=\"10\" fill=\"white\" />\n        <circle cx=\"125\" cy=\"80\" r=\"10\" fill=\"white\" />\n        <path d=\"M65 60 L 85 70\" stroke=\"white\" stroke-width=\"4\" stroke-linecap=\"round\" />\n        <path d=\"M135 60 L 115 70\" stroke=\"white\" stroke-width=\"4\" stroke-linecap=\"round\" />\n        <defs>\n          <linearGradient id=\"paint0_linear_404\" x1=\"20\" y1=\"20\" x2=\"180\" y2=\"180\" gradientUnits=\"userSpaceOnUse\">\n            <stop stop-color=\"#F43F5E\" />\n            <stop offset=\"1\" stop-color=\"#BE123C\" />\n          </linearGradient>\n        </defs>\n      </svg>\n      <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-rose-500 border-rose-100 dark:border-rose-900/30 bg-rose-50 dark:bg-rose-500/10\">\n        <i data-lucide=\"shield-alert\" class=\"w-16 h-16 text-rose-500 animate-bounce\"></i>\n      </div>\n    </div>\n\n    <!-- Code Label -->\n    <div class=\"space-y-3 pt-6\">\n      <span class=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n        404\n      </span>\n      <h2 class=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n        Page Not Found\n      </h2>\n      <p class=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n        원하시는 페이지를 찾을 수 없습니다.\n      </p>\n      <p class=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n        입력하신 주소가 잘못되었거나, 페이지가 삭제 혹은 이동되었을 수 있습니다. 주소를 다시 한번 확인해 주세요.\n      </p>\n    </div>\n\n    <!-- Navigation Buttons -->\n    <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n      <button onclick=\"history.back()\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\">\n        <i data-lucide=\"arrow-left\" class=\"w-4 h-4\"></i>\n        이전으로\n      </button>\n      <button onclick=\"location.href='/'\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\">\n        <i data-lucide=\"home\" class=\"w-4 h-4\"></i>\n        대시보드로 돌아가기\n      </button>\n    </div>\n  </div>\n</div>",
    "css": "/* 기본 Tailwind CSS 클래스를 활용하므로, 별도 빌드용 커스텀 스타일 정의가 불필요합니다. */",
    "js": "document.addEventListener('DOMContentLoaded', () => {\n  if (typeof lucide !== 'undefined') {\n    lucide.createIcons();\n  }\n});",
    "fullHtml": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest\"></script>\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css\">\n  <title>Error 404 - Page Not Found</title>\n  <style>\n    body {\n      font-family: 'Pretendard', sans-serif;\n    }\n  </style>\n</head>\n<body class=\"bg-slate-50 dark:bg-slate-900 transition-colors duration-300\">\n  <div class=\"w-full min-h-screen flex items-center justify-center p-4\">\n    <div class=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl transition-all duration-300\">\n      <div class=\"relative\">\n        <svg class=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <circle cx=\"100\" cy=\"100\" r=\"80\" fill=\"url(#paint0_linear_404)\" class=\"animate-pulse\" />\n          <path d=\"M70 120 C 85 105, 115 105, 130 120\" stroke=\"white\" stroke-width=\"6\" stroke-linecap=\"round\" />\n          <circle cx=\"75\" cy=\"80\" r=\"10\" fill=\"white\" />\n          <circle cx=\"125\" cy=\"80\" r=\"10\" fill=\"white\" />\n          <path d=\"M65 60 L 85 70\" stroke=\"white\" stroke-width=\"4\" stroke-linecap=\"round\" />\n          <path d=\"M135 60 L 115 70\" stroke=\"white\" stroke-width=\"4\" stroke-linecap=\"round\" />\n          <defs>\n            <linearGradient id=\"paint0_linear_404\" x1=\"20\" y1=\"20\" x2=\"180\" y2=\"180\" gradientUnits=\"userSpaceOnUse\">\n              <stop stop-color=\"#F43F5E\" />\n              <stop offset=\"1\" stop-color=\"#BE123C\" />\n            </linearGradient>\n          </defs>\n        </svg>\n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-rose-500 border-rose-100 dark:border-rose-900/30 bg-rose-50 dark:bg-rose-500/10\">\n          <i data-lucide=\"shield-alert\" class=\"w-16 h-16 text-rose-500 animate-bounce\"></i>\n        </div>\n      </div>\n      <div class=\"space-y-3 pt-6\">\n        <span class=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n          404\n        </span>\n        <h2 class=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n          Page Not Found\n        </h2>\n        <p class=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n          원하시는 페이지를 찾을 수 없습니다.\n        </p>\n        <p class=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n          입력하신 주소가 잘못되었거나, 페이지가 삭제 혹은 이동되었을 수 있습니다. 주소를 다시 한번 확인해 주세요.\n        </p>\n      </div>\n      <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n        <button onclick=\"history.back()\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\">\n          <i data-lucide=\"arrow-left\" class=\"w-4 h-4\"></i>\n          이전으로\n        </button>\n        <button onclick=\"location.href='/'\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\">\n          <i data-lucide=\"home\" class=\"w-4 h-4\"></i>\n          대시보드로 돌아가기\n        </button>\n      </div>\n    </div>\n  </div>\n  <script>\n    lucide.createIcons();\n  </script>\n</body>\n</html>"
  },
  "500": {
    "react": "import React from 'react';\nimport { ArrowLeft, RotateCcw, AlertTriangle } from 'lucide-react';\n\nconst Error500Page: React.FC = () => {\n  const handleReload = () => {\n    window.location.reload();\n  };\n\n  return (\n    <div className=\"w-full flex items-center justify-center bg-slate-50 dark:bg-slate-900 px-4 py-10 transition-colors duration-300 font-sans\">\n      <div className=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl\">\n        <div className=\"relative\">\n          <svg className=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <rect x=\"30\" y=\"30\" width=\"140\" height=\"140\" rx=\"20\" fill=\"url(#paint0_linear_500)\" />\n            <path d=\"M60 85 L 140 85 M60 115 L 140 115\" stroke=\"white\" strokeWidth=\"6\" strokeLinecap=\"round\" />\n            <circle cx=\"80\" cy=\"85\" r=\"4\" fill=\"#F59E0B\" className=\"animate-ping\" />\n            <circle cx=\"120\" cy=\"115\" r=\"4\" fill=\"#F59E0B\" className=\"animate-ping\" />\n            <defs>\n              <linearGradient id=\"paint0_linear_500\" x1=\"30\" y1=\"30\" x2=\"170\" y2=\"170\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#F59E0B\" />\n                <stop offset=\"1\" stopColor=\"#D97706\" />\n              </linearGradient>\n            </defs>\n          </svg>\n          <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-amber-500 border-amber-100 dark:border-amber-900/30 bg-amber-50 dark:bg-amber-500/10\">\n            <AlertTriangle className=\"w-16 h-16 text-amber-500 animate-pulse\" />\n          </div>\n        </div>\n        <div className=\"space-y-3 pt-6\">\n          <span className=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n            500\n          </span>\n          <h2 className=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n            Internal Server Error\n          </h2>\n          <p className=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n            서버 내부 오류가 발생했습니다.\n          </p>\n          <p className=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n            웹서버가 일시적인 요청 과부하 상태이거나 시스템 내부 점검 중입니다. 서비스 이용에 불편을 드려 대단히 죄송합니다.\n          </p>\n        </div>\n        <div className=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n          <button\n            onClick={() => window.history.back()}\n            className=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\"\n          >\n            <ArrowLeft className=\"w-4 h-4\" />\n            이전으로\n          </button>\n          <button\n            onClick={handleReload}\n            className=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\"\n          >\n            <RotateCcw className=\"w-4 h-4\" />\n            새로고침 시도\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default Error500Page;",
    "html": "<div class=\"w-full flex items-center justify-center bg-slate-50 dark:bg-slate-900 px-4 py-10 transition-colors duration-300 font-sans\">\n  <div class=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl transition-all duration-300\">\n    <!-- Error Badge & Illustration -->\n    <div class=\"relative\">\n      <svg class=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"30\" y=\"30\" width=\"140\" height=\"140\" rx=\"20\" fill=\"url(#paint0_linear_500)\" />\n        <path d=\"M60 85 L 140 85 M60 115 L 140 115\" stroke=\"white\" stroke-width=\"6\" stroke-linecap=\"round\" />\n        <circle cx=\"80\" cy=\"85\" r=\"4\" fill=\"#F59E0B\" class=\"animate-ping\" />\n        <circle cx=\"120\" cy=\"115\" r=\"4\" fill=\"#F59E0B\" class=\"animate-ping\" />\n        <defs>\n          <linearGradient id=\"paint0_linear_500\" x1=\"30\" y1=\"30\" x2=\"170\" y2=\"170\" gradientUnits=\"userSpaceOnUse\">\n            <stop stop-color=\"#F59E0B\" />\n            <stop offset=\"1\" stop-color=\"#D97706\" />\n          </linearGradient>\n        </defs>\n      </svg>\n      <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-amber-500 border-amber-100 dark:border-amber-900/30 bg-amber-50 dark:bg-amber-500/10\">\n        <i data-lucide=\"alert-triangle\" class=\"w-16 h-16 text-amber-500 animate-pulse\"></i>\n      </div>\n    </div>\n\n    <!-- Code Label -->\n    <div class=\"space-y-3 pt-6\">\n      <span class=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n        500\n      </span>\n      <h2 class=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n        Internal Server Error\n      </h2>\n      <p class=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n        서버 내부 오류가 발생했습니다.\n      </p>\n      <p class=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n        웹서버가 일시적인 요청 과부하 상태이거나 시스템 내부 점검 중입니다. 서비스 이용에 불편을 드려 대단히 죄송합니다.\n      </p>\n    </div>\n\n    <!-- Navigation Buttons -->\n    <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n      <button onclick=\"history.back()\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\">\n        <i data-lucide=\"arrow-left\" class=\"w-4 h-4\"></i>\n        이전으로\n      </button>\n      <button onclick=\"location.reload()\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\">\n        <i data-lucide=\"refresh-cw\" class=\"w-4 h-4\"></i>\n        새로고침 시도\n      </button>\n    </div>\n  </div>\n</div>",
    "css": "/* 기본 Tailwind CSS 클래스를 활용하므로, 별도 빌드용 커스텀 스타일 정의가 불필요합니다. */",
    "js": "document.addEventListener('DOMContentLoaded', () => {\n  if (typeof lucide !== 'undefined') {\n    lucide.createIcons();\n  }\n});",
    "fullHtml": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest\"></script>\n  <link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/static/pretendard.css\">\n  <title>Error 500 - Internal Server Error</title>\n  <style>\n    body {\n      font-family: 'Pretendard', sans-serif;\n    }\n  </style>\n</head>\n<body class=\"bg-slate-50 dark:bg-slate-900 transition-colors duration-300\">\n  <div class=\"w-full min-h-screen flex items-center justify-center p-4\">\n    <div class=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl transition-all duration-300\">\n      <div class=\"relative\">\n        <svg class=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n          <rect x=\"30\" y=\"30\" width=\"140\" height=\"140\" rx=\"20\" fill=\"url(#paint0_linear_500)\" />\n          <path d=\"M60 85 L 140 85 M60 115 L 140 115\" stroke=\"white\" stroke-width=\"6\" stroke-linecap=\"round\" />\n          <circle cx=\"80\" cy=\"85\" r=\"4\" fill=\"#F59E0B\" class=\"animate-ping\" />\n          <circle cx=\"120\" cy=\"115\" r=\"4\" fill=\"#F59E0B\" class=\"animate-ping\" />\n          <defs>\n            <linearGradient id=\"paint0_linear_500\" x1=\"30\" y1=\"30\" x2=\"170\" y2=\"170\" gradientUnits=\"userSpaceOnUse\">\n              <stop stop-color=\"#F59E0B\" />\n              <stop offset=\"1\" stop-color=\"#D97706\" />\n            </linearGradient>\n          </defs>\n        </svg>\n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-amber-500 border-amber-100 dark:border-amber-900/30 bg-amber-50 dark:bg-amber-500/10\">\n          <i data-lucide=\"alert-triangle\" class=\"w-16 h-16 text-amber-500 animate-pulse\"></i>\n        </div>\n      </div>\n      <div class=\"space-y-3 pt-6\">\n        <span class=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n          500\n        </span>\n        <h2 class=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n          Internal Server Error\n        </h2>\n        <p class=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n          서버 내부 오류가 발생했습니다.\n        </p>\n        <p class=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n          웹서버가 일시적인 요청 과부하 상태이거나 시스템 내부 점검 중입니다. 서비스 이용에 불편을 드려 대단히 죄송합니다.\n        </p>\n      </div>\n      <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n        <button onclick=\"history.back()\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\">\n          <i data-lucide=\"arrow-left\" class=\"w-4 h-4\"></i>\n          이전으로\n        </button>\n        <button onclick=\"location.reload()\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\">\n          <i data-lucide=\"refresh-cw\" class=\"w-4 h-4\"></i>\n          새로고침 시도\n        </button>\n      </div>\n    </div>\n  </div>\n  <script>\n    lucide.createIcons();\n  </script>\n</body>\n</html>"
  },
  "503": {
    "react": "import React from 'react';\nimport { useNavigate } from 'react-router-dom';\nimport { ArrowLeft, Home, Cpu } from 'lucide-react';\n\nconst Error503Page: React.FC = () => {\n  const navigate = useNavigate();\n\n  return (\n    <div className=\"w-full flex items-center justify-center bg-slate-50 dark:bg-slate-900 px-4 py-10 transition-colors duration-300 font-sans\">\n      <div className=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl\">\n        <div className=\"relative\">\n          <svg className=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n            <rect x=\"40\" y=\"40\" width=\"120\" height=\"120\" rx=\"16\" fill=\"url(#paint0_linear_503)\" />\n            <path d=\"M100 20 L 100 40 M100 160 L 100 180 M20 100 L 40 100 M160 100 L 180 100\" stroke=\"#6366F1\" strokeWidth=\"6\" strokeLinecap=\"round\" className=\"animate-pulse\" />\n            <circle cx=\"100\" cy=\"100\" r=\"30\" fill=\"white\" fillOpacity=\"0.2\" />\n            <circle cx=\"100\" cy=\"100\" r=\"15\" fill=\"white\" className=\"animate-ping\" />\n            <defs>\n              <linearGradient id=\"paint0_linear_503\" x1=\"40\" y1=\"40\" x2=\"160\" y2=\"160\" gradientUnits=\"userSpaceOnUse\">\n                <stop stopColor=\"#6366F1\" />\n                <stop offset=\"1\" stopColor=\"#4F46E5\" />\n              </linearGradient>\n            </defs>\n          </svg>\n          <div className=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-indigo-500 border-indigo-100 dark:border-indigo-900/30 bg-indigo-50 dark:bg-indigo-500/10\">\n            <Cpu className=\"w-16 h-16 text-indigo-500 animate-spin-slow\" style={{ animationDuration: '6s' }} />\n          </div>\n        </div>\n        <div className=\"space-y-3 pt-6\">\n          <span className=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n            503\n          </span>\n          <h2 className=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n            Service Unavailable\n          </h2>\n          <p className=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n            서비스 점검 중입니다.\n          </p>\n          <p className=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n            더 나은 서비스를 제공하기 위해 현재 시스템 점검 및 서버 업그레이드 작업이 진행 중입니다. 곧 안전하고 빠른 서비스로 찾아뵙겠습니다.\n          </p>\n        </div>\n        <div className=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n          <button\n            onClick={() => navigate(-1)}\n            className=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\"\n          >\n            <ArrowLeft className=\"w-4 h-4\" />\n            이전으로\n          </button>\n          <button\n            onClick={() => navigate('/')}\n            className=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\"\n          >\n            <Home className=\"w-4 h-4\" />\n            대시보드로 돌아가기\n          </button>\n        </div>\n      </div>\n    </div>\n  );\n};\n\nexport default Error503Page;",
    "html": "<div class=\"w-full flex items-center justify-center bg-slate-50 dark:bg-slate-900 px-4 py-10 transition-colors duration-300 font-sans\">\n  <div class=\"w-full max-w-xl text-center space-y-8 bg-white dark:bg-[#1A222C] p-8 sm:p-12 rounded-3xl border border-slate-100 dark:border-slate-800 shadow-xl transition-all duration-300\">\n    <!-- Error Badge & Illustration -->\n    <div class=\"relative\">\n      <svg class=\"w-full max-w-[320px] h-auto mx-auto mb-6 opacity-90 dark:opacity-80\" viewBox=\"0 0 200 200\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\">\n        <rect x=\"40\" y=\"40\" width=\"120\" height=\"120\" rx=\"16\" fill=\"url(#paint0_linear_503)\" />\n        <path d=\"M100 20 L 100 40 M100 160 L 100 180 M20 100 L 40 100 M160 100 L 180 100\" stroke=\"#6366F1\" stroke-width=\"6\" stroke-linecap=\"round\" class=\"animate-pulse\" />\n        <circle cx=\"100\" cy=\"100\" r=\"30\" fill=\"white\" fill-opacity=\"0.2\" />\n        <circle cx=\"100\" cy=\"100\" r=\"15\" fill=\"white\" class=\"animate-ping\" />\n        <defs>\n          <linearGradient id=\"paint0_linear_503\" x1=\"40\" y1=\"40\" x2=\"160\" y2=\"160\" gradientUnits=\"userSpaceOnUse\">\n            <stop stop-color=\"#6366F1\" />\n            <stop offset=\"1\" stop-color=\"#4F46E5\" />\n          </linearGradient>\n        </defs>\n      </svg>\n      <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 p-5 rounded-full border shadow-lg bg-white dark:bg-[#18202b] text-indigo-500 border-indigo-100 dark:border-indigo-900/30 bg-indigo-50 dark:bg-indigo-500/10\">\n        <i data-lucide=\"cpu\" class=\"w-16 h-16 text-indigo-500 animate-spin-slow\" style=\"animation-duration: 6s;\"></i>\n      </div>\n    </div>\n\n    <!-- Code Label -->\n    <div class=\"space-y-3 pt-6\">\n      <span class=\"text-[64px] font-black tracking-widest text-slate-300 dark:text-slate-700 leading-none\">\n        503\n      </span>\n      <h2 class=\"text-[26px] font-extrabold text-slate-800 dark:text-white leading-tight\">\n        Service Unavailable\n      </h2>\n      <p class=\"text-lg font-bold text-slate-700 dark:text-slate-300\">\n        서비스 점검 중입니다.\n      </p>\n      <p class=\"text-sm font-medium text-slate-400 dark:text-slate-500 leading-relaxed\">\n        더 나은 서비스를 제공하기 위해 현재 시스템 점검 및 서버 업그레이드 작업이 진행 중입니다. 곧 안전하고 빠른 서비스로 찾아뵙겠습니다.\n      </p>\n    </div>\n\n    <!-- Navigation Buttons -->\n    <div class=\"flex flex-col sm:flex-row items-center justify-center gap-4 pt-4\">\n      <button onclick=\"history.back()\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 border border-slate-200 dark:border-slate-700 rounded-xl text-sm font-bold text-slate-700 dark:text-slate-300 hover:bg-slate-50 dark:hover:bg-slate-800 transition-all cursor-pointer\">\n        <i data-lucide=\"arrow-left\" class=\"w-4 h-4\"></i>\n        이전으로\n      </button>\n      <button onclick=\"location.href='/'\" class=\"w-full sm:w-auto flex items-center justify-center gap-2 px-6 py-3 bg-[#4B62FA] hover:bg-indigo-600 rounded-xl text-sm font-bold text-white transition-all shadow-lg shadow-indigo-100 dark:shadow-none cursor-pointer\">\n        <i data-lucide=\"home\" class=\"w-4 h-4\"></i>\n        대시보드로 돌아가기\n      </button>\n    </div>\n  </div>\n</div>",
