-cover\" src=\"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&h=100&fit=crop\" alt=\"member\" />\n          </div>\n          <span className=\"text-xs font-bold text-slate-500 dark:text-slate-400 ml-3\">+ 12명 참여 중</span>\n        </div>\n      </div>\n    </div>\n  );\n};",
    "html": "<div class=\"space-y-4 p-4\">\n  <!-- Basic shapes -->\n  <div class=\"space-y-2\">\n    <h4 class=\"text-[11px] font-bold text-slate-400 uppercase tracking-wider\">기본 모양 (Shape)</h4>\n    <div class=\"flex items-center gap-3\">\n      <div class=\"w-12 h-12 rounded-full overflow-hidden border border-slate-200 bg-slate-50\">\n        <img src=\"https://i.pravatar.cc/150?u=3\" alt=\"avatar\" class=\"w-full h-full object-cover\" />\n      </div>\n      <div class=\"w-12 h-12 rounded-xl overflow-hidden border border-slate-200 bg-slate-50\">\n        <img src=\"https://i.pravatar.cc/150?u=3\" alt=\"avatar\" class=\"w-full h-full object-cover\" />\n      </div>\n      <div class=\"w-12 h-12 rounded-full bg-indigo-500 text-white flex items-center justify-center font-bold text-sm shadow-sm\">\n        JW\n      </div>\n    </div>\n  </div>\n\n  <!-- Team Avatars -->\n  <div class=\"space-y-2 pt-2\">\n    <h4 class=\"text-[11px] font-bold text-slate-400 uppercase tracking-wider\">아바타 그룹 (Team Members)</h4>\n    <div class=\"flex items-center\">\n      <div class=\"flex -space-x-3 overflow-hidden\">\n        <img class=\"inline-block h-10 w-10 rounded-full ring-2 ring-white object-cover\" src=\"https://images.unsplash.com/photo-1491528323818-fdd1faba62cc?w=100&h=100&fit=crop\" alt=\"member\" />\n        <img class=\"inline-block h-10 w-10 rounded-full ring-2 ring-white object-cover\" src=\"https://images.unsplash.com/photo-1550525811-e5869dd03032?w=100&h=100&fit=crop\" alt=\"member\" />\n        <img class=\"inline-block h-10 w-10 rounded-full ring-2 ring-white object-cover\" src=\"https://images.unsplash.com/photo-1500648767791-00dcc994a43e?w=100&h=100&fit=crop\" alt=\"member\" />\n      </div>\n      <span class=\"text-xs font-bold text-slate-550 ml-3\">+ 12명 참여 중</span>\n    </div>\n  </div>\n</div>",
