    "js": "const modal = document.getElementById('event-modal');\nconst addBtn = document.getElementById('add-event-btn');\n\nfunction openModal() {\n  modal.classList.remove('hidden');\n}\n\nfunction closeModal() {\n  modal.classList.add('hidden');\n}\n\nif (addBtn) {\n  addBtn.addEventListener('click', openModal);\n}",
    "fullHtml": "<!DOCTYPE html>\n<html lang=\"ko\">\n<head>\n  <meta charset=\"UTF-8\">\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n  <title>Calendar Preview</title>\n  <script src=\"https://cdn.tailwindcss.com\"></script>\n  <script src=\"https://unpkg.com/lucide@latest\"></script>\n  <script>\n    tailwind.config = {\n      darkMode: 'class',\n      theme: {\n        extend: {\n          colors: {\n            primary: '#4B62FA'\n          }\n        }\n      }\n    }\n  </script>\n  <style>\n    body {\n      font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif;\n    }\n  </style>\n</head>\n<body class=\"bg-slate-50 dark:bg-[#0F172A] p-4 transition-colors duration-300\">\n  <div class=\"bg-white dark:bg-[#1E293B] rounded-2xl p-6 transition-all duration-300 shadow-sm\">\n    <!-- Calendar Header -->\n    <div class=\"flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6\">\n      <div class=\"flex items-center gap-4\">\n        <h2 class=\"text-[20px] font-black text-slate-900 dark:text-white\">March 2026</h2>\n        <div class=\"flex items-center gap-1.5\">\n          <button class=\"p-2 rounded-lg bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700 transition-colors cursor-pointer\">\n            <i data-lucide=\"chevron-left\" class=\"w-4 h-4\"></i>\n          </button>\n          <button class=\"p-2 rounded-lg bg-slate-50 hover:bg-slate-100 dark:bg-slate-800 dark:hover:bg-slate-700 text-slate-600 dark:text-slate-300 border border-slate-200 dark:border-slate-700 transition-colors cursor-pointer\">\n            <i data-lucide=\"chevron-right\" class=\"w-4 h-4\"></i>\n          </button>\n        </div>\n      </div>\n      <div class=\"flex flex-wrap items-center gap-3\">\n        <div class=\"flex items-center p-1 bg-slate-50 dark:bg-slate-800 rounded-lg border border-slate-200 dark:border-slate-700 w-fit\">\n          <button class=\"px-4 py-1.5 rounded-md text-[13px] font-bold bg-white dark:bg-slate-700 text-slate-900 dark:text-white shadow-sm transition-all cursor-pointer\">월간</button>\n          <button class=\"px-4 py-1.5 rounded-md text-[13px] font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all cursor-pointer\">주간</button>\n          <button class=\"px-4 py-1.5 rounded-md text-[13px] font-bold text-slate-500 hover:text-slate-700 dark:text-slate-400 dark:hover:text-slate-200 transition-all cursor-pointer\">일간</button>\n        </div>\n        <button id=\"add-event-btn\" class=\"flex items-center justify-center gap-2 px-5 py-2 rounded-xl bg-[#4B62FA] hover:bg-indigo-600 text-white text-[13px] font-bold shadow-md transition-all active:scale-95 cursor-pointer\">\n          <i data-lucide=\"plus\" class=\"w-4 h-4\"></i>\n          이벤트 추가\n        </button>\n      </div>\n    </div>\n\n    <!-- Calendar Grid -->\n    <div class=\"grid grid-cols-7 border-t border-slate-200 dark:border-slate-700\">\n      <!-- Days of Week -->\n      <div class=\"py-3 text-center text-[12px] font-bold text-slate-400 dark:text-slate-500 border-b border-slate-200 dark:border-slate-700\">일</div>\n      <div class=\"py-3 text-center text-[12px] font-bold text-slate-400 dark:text-slate-500 border-b border-slate-200 dark:border-slate-700\">월</div>\n      <div class=\"py-3 text-center text-[12px] font-bold text-slate-400 dark:text-slate-500 border-b border-slate-200 dark:border-slate-700\">화</div>\n      <div class=\"py-3 text-center text-[12px] font-bold text-slate-400 dark:text-slate-500 border-b border-slate-200 dark:border-slate-700\">수</div>\n      <div class=\"py-3 text-center text-[12px] font-bold text-slate-400 dark:text-slate-500 border-b border-slate-200 dark:border-slate-700\">목</div>\n      <div class=\"py-3 text-center text-[12px] font-bold text-slate-400 dark:text-slate-500 border-b border-slate-200 dark:border-slate-700\">금</div>\n      <div class=\"py-3 text-center text-[12px] font-bold text-slate-400 dark:text-slate-500 border-b border-slate-200 dark:border-slate-700\">토</div>\n\n      <!-- Calendar Cells -->\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">1</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">2</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">3</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">4</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">5</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">6</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">7</span></div>\n      </div>\n\n      <!-- Row 2 -->\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">8</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">9</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">10</span></div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">11</span></div>\n        <div class=\"space-y-1\">\n          <div class=\"px-2 py-0.5 rounded text-[11px] font-bold truncate bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border-l-4 border-red-500\">이벤트 컨퍼런스</div>\n        </div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">12</span></div>\n        <div class=\"space-y-1\">\n          <div class=\"px-2 py-0.5 rounded text-[11px] font-bold truncate bg-emerald-50 dark:bg-emerald-500/10 text-emerald-600 dark:text-emerald-400 border-l-4 border-emerald-500\">회의</div>\n        </div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-r border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">13</span></div>\n        <div class=\"space-y-1\">\n          <div class=\"px-2 py-0.5 rounded text-[11px] font-bold truncate bg-indigo-50 dark:bg-indigo-500/10 text-indigo-600 dark:text-indigo-400 border-l-4 border-[#4B62FA]\">워크샵</div>\n        </div>\n      </div>\n      <div class=\"min-h-[100px] p-2 border-b border-slate-200 dark:border-slate-700 cursor-pointer hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-all\">\n        <div class=\"flex justify-start mb-1\"><span class=\"text-[13px] font-bold text-slate-800 dark:text-slate-200\">14</span></div>\n      </div>\n    </div>\n  </div>\n\n  <!-- Event Modal -->\n  <div id=\"event-modal\" class=\"fixed inset-0 z-50 flex items-center justify-center p-4 hidden\">\n    <div class=\"absolute inset-0 bg-slate-900/40 backdrop-blur-sm\" onclick=\"closeModal()\"></div>\n    <div class=\"relative w-full max-w-[480px] bg-white dark:bg-slate-900 rounded-[24px] shadow-2xl p-6 transition-all duration-300\">\n      <div class=\"flex justify-between items-center mb-4\">\n        <h3 class=\"text-lg font-black text-slate-800 dark:text-white\">이벤트 추가</h3>\n        <button onclick=\"closeModal()\" class=\"w-8 h-8 rounded-full flex items-center justify-center hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-400 cursor-pointer\">\n          <i data-lucide=\"x\" class=\"w-5 h-5\"></i>\n        </button>\n      </div>\n      <input type=\"text\" placeholder=\"제목 입력\" class=\"w-full px-4 py-3 rounded-xl border border-slate-200 dark:border-slate-700 focus:outline-none bg-transparent mb-4 text-slate-700 dark:text-slate-300\">\n      <div class=\"flex justify-end gap-2\">\n        <button onclick=\"closeModal()\" class=\"px-4 py-2 rounded-xl border border-slate-200 dark:border-slate-700 text-slate-600 dark:text-slate-400 cursor-pointer\">취소</button>\n        <button onclick=\"closeModal()\" class=\"px-4 py-2 rounded-xl bg-[#4B62FA] text-white cursor-pointer\">저장</button>\n      </div>\n    </div>\n  </div>\n\n  <script>\n    document.addEventListener('DOMContentLoaded', () => {\n      lucide.createIcons();\n    });\n    const modal = document.getElementById('event-modal');\n    const addBtn = document.getElementById('add-event-btn');\n\n    function openModal() {\n      modal.classList.remove('hidden');\n    }\n\n    function closeModal() {\n      modal.classList.add('hidden');\n    }\n\n    if (addBtn) {\n      addBtn.addEventListener('click', openModal);\n    }\n  </script>\n</body>\n</html>"
